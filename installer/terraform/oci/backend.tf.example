# ============================================================================
# Terraform State Backend
# ============================================================================
# IMPORTANT: Uncomment and configure before first run.
# Without a remote backend, Terraform state is lost when the installer
# container exits. Re-running will attempt to recreate all resources.
#
# AWS: Use S3
# terraform {
#   backend "s3" {
#     bucket = "katonic-terraform-state"
#     key    = "v7/cluster/terraform.tfstate"
#     region = "us-east-1"
#   }
# }
#
# GCP: Use GCS
# terraform {
#   backend "gcs" {
#     bucket = "katonic-terraform-state"
#     prefix = "v7/cluster"
#   }
# }
#
# OCI/Alibaba: Use S3-compatible backend
# terraform {
#   backend "s3" {
#     bucket   = "katonic-terraform-state"
#     key      = "v7/cluster/terraform.tfstate"
#     endpoint = "https://<namespace>.compat.objectstorage.<region>.oraclecloud.com"
#     region   = "<region>"
#     skip_credentials_validation = true
#     skip_metadata_api_check     = true
#     force_path_style            = true
#   }
# }
